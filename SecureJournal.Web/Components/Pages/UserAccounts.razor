@page "/admin/user-accounts"
@attribute [Authorize(Roles = "Administrator")]
@inject NavigationManager Navigation

<PageTitle>User Management</PageTitle>

<section class="page-head">
    <div>
        <p class="eyebrow">Administration</p>
        <h2>User Management</h2>
        <p>Redirecting to the consolidated user management page.</p>
    </div>
</section>

<section class="panel-card redirect-card">
    <p class="mb-0">Taking you there now...</p>
</section>

@code {
    protected override void OnInitialized()
    {
        Navigation.NavigateTo("/admin/users", forceLoad: false);
    }
}
