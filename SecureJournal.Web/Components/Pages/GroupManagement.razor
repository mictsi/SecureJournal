@page "/admin/groups"
@attribute [Authorize(Roles = "Administrator")]
@inject ISecureJournalAppService JournalApp
@inject NavigationManager Navigation
@inject ILogger<GroupManagement> Logger

<PageTitle>Group Management</PageTitle>

<section class="page-head">
    <div>
        <p class="eyebrow">Administration</p>
        <h2>Group Management</h2>
        <p>Create groups, search existing groups, and manage group members.</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger" role="alert">@_error</div>
}

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert alert-success" role="alert">@_message</div>
}

@if (_currentUser is null)
{
    <p>Loading current user...</p>
}
else if (_currentUser.Role != AppRole.Administrator)
{
    <div class="alert alert-warning" role="alert">
        Administrator access is required. Current user: <strong>@_currentUser.DisplayName</strong> (@_currentUser.Role).
    </div>
}
else
{
    <section class="panel-card group-create-card mb-4">
        <div class="panel-card-header">
            <h3>Create group</h3>
            <div class="panel-card-header-actions">
                <button type="button" class="btn btn-primary btn-sm" @onclick="ToggleCreateGroupForm">
                    @(_showCreateGroupForm ? "Hide form" : "Create group")
                </button>
            </div>
        </div>

        @if (_showCreateGroupForm)
        {
            <EditForm Model="GroupDraft" OnValidSubmit="CreateGroupAsync" FormName="admin-group-create">
                <AntiforgeryToken />
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label" for="groupName">Group Name</label>
                        <InputText id="groupName" class="form-control" maxlength="100" @bind-Value="GroupDraft.Name" />
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="groupDescription">Description</label>
                        <InputTextArea id="groupDescription" class="form-control" rows="3" maxlength="500" @bind-Value="GroupDraft.Description" />
                    </div>
                </div>

                <div class="mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary" disabled="@_isCreating">
                        @(_isCreating ? "Creating..." : "Create group")
                    </button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="ResetGroupForm" disabled="@_isCreating">Reset</button>
                </div>
            </EditForm>
        }
        else
        {
            <p class="mb-0">Use the button above to add a new group without leaving this page.</p>
        }
    </section>

    <section class="panel-card group-list-card">
        <div class="panel-card-header">
            <h3>Groups</h3>
            <div class="panel-card-header-actions">
                <span class="text-muted">@_groupPage.TotalCount total</span>
                <label class="project-page-size-label" for="groupPageSize">Page size</label>
                <select id="groupPageSize"
                        class="form-select form-select-sm project-page-size-select"
                        @onchange="OnPageSizeChanged">
                    @foreach (var option in _pageSizeOptions)
                    {
                        <option value="@option" selected="@(option == _groupQuery.PageSize)">@option</option>
                    }
                </select>
            </div>
        </div>

        <div class="row g-2 mb-3">
            <div class="col-md-8">
                <label class="form-label" for="groupSearch">Search groups</label>
                <input id="groupSearch"
                       class="form-control"
                       type="text"
                       value="@_groupQuery.FilterText"
                       @oninput="OnSearchChanged"
                       placeholder="Filter by name or description..." />
            </div>
        </div>

        @if (_groupPage.TotalCount == 0)
        {
            <p class="mb-0">No groups found.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm group-table mb-0">
                    <thead>
                        <tr>
                            <th><button type="button" class="btn btn-link p-0 table-sort" @onclick="@(() => ChangeSortAsync("name"))">Name @SortGlyph("name", _groupQuery.SortField, _groupQuery.SortDirection)</button></th>
                            <th><button type="button" class="btn btn-link p-0 table-sort" @onclick="@(() => ChangeSortAsync("description"))">Description @SortGlyph("description", _groupQuery.SortField, _groupQuery.SortDirection)</button></th>
                            <th>Members</th>
                            <th>Projects</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var group in _groupPage.Items)
                        {
                            <tr>
                                <td>@group.Name</td>
                                <td>@RenderValueOrDash(group.Description)</td>
                                <td>@FormatList(group.Members)</td>
                                <td>@FormatList(group.ProjectCodes)</td>
                                <td>
                                    <div class="d-flex flex-wrap gap-2">
                                        <button type="button"
                                                class="btn btn-outline-primary btn-sm"
                                                @onclick="() => ToggleManageMembersAsync(group.GroupId, group.Name)">
                                            @(IsManagingGroup(group.GroupId) ? "Close members" : "Manage members")
                                        </button>
                                        <button type="button"
                                                class="btn btn-outline-danger btn-sm"
                                                @onclick="() => DeleteGroupAsync(group.GroupId, group.Name)"
                                                disabled="@(_isDeleting && _deletingGroupId == group.GroupId)">
                                            @(_isDeleting && _deletingGroupId == group.GroupId ? "Deleting..." : "Delete")
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="pager-bar">
                <span class="text-muted">Page @_groupPage.Page of @_groupPage.TotalPages</span>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="GoToPreviousPageAsync" disabled="@(_groupQuery.Page <= 1)">Previous</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="GoToNextPageAsync" disabled="@(_groupQuery.Page >= _groupPage.TotalPages)">Next</button>
                </div>
            </div>
        }
    </section>

    @if (_selectedGroupId.HasValue)
    {
        <section class="panel-card group-members-card mt-4">
            <div class="panel-card-header">
                <div>
                    <h3>Manage members</h3>
                    <p class="mb-0 text-muted">Update membership for <strong>@SelectedGroupName</strong>.</p>
                </div>
                <span class="text-muted">@_groupUserPage.TotalCount total users</span>
            </div>

            <div class="row g-2 mb-3">
                <div class="col-lg-5 col-md-12">
                    <label class="form-label" for="groupUserSearch">Search users</label>
                    <input id="groupUserSearch"
                           class="form-control"
                           type="text"
                           value="@_groupUserQuery.FilterText"
                           @oninput="OnGroupUserSearchChanged"
                           placeholder="Filter by username or display name..." />
                </div>
                <div class="col-lg-3 col-md-6">
                    <label class="form-label" for="groupUserAssigned">Assigned</label>
                    <select id="groupUserAssigned" class="form-select" @onchange="OnGroupUserAssignedFilterChanged">
                        <option value="all" selected="@(!_groupUserQuery.Assigned.HasValue)">All</option>
                        <option value="assigned" selected="@(_groupUserQuery.Assigned == true)">Assigned</option>
                        <option value="unassigned" selected="@(_groupUserQuery.Assigned == false)">Unassigned</option>
                    </select>
                </div>
                <div class="col-lg-3 col-md-6">
                    <label class="form-label" for="groupUserPageSize">Page size</label>
                    <select id="groupUserPageSize" class="form-select" @onchange="OnGroupUserPageSizeChanged">
                        @foreach (var option in _pageSizeOptions)
                        {
                            <option value="@option" selected="@(option == _groupUserQuery.PageSize)">@option</option>
                        }
                    </select>
                </div>
            </div>

            @if (_groupUserPage.TotalCount == 0)
            {
                <p class="mb-0">No users available for the current filter.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th><button type="button" class="btn btn-link p-0 table-sort" @onclick="@(() => ChangeGroupUserSortAsync("username"))">Username @SortGlyph("username", _groupUserQuery.SortField, _groupUserQuery.SortDirection)</button></th>
                                <th><button type="button" class="btn btn-link p-0 table-sort" @onclick="@(() => ChangeGroupUserSortAsync("displayName"))">Display Name @SortGlyph("displayName", _groupUserQuery.SortField, _groupUserQuery.SortDirection)</button></th>
                                <th class="text-end"><button type="button" class="btn btn-link p-0 table-sort" @onclick="@(() => ChangeGroupUserSortAsync("assigned"))">Assigned @SortGlyph("assigned", _groupUserQuery.SortField, _groupUserQuery.SortDirection)</button></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in _groupUserPage.Items)
                            {
                                <tr>
                                    <td>@user.Username</td>
                                    <td>@user.DisplayName</td>
                                    <td class="text-end">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               checked="@IsUserAssigned(user)"
                                               @onchange="args => ToggleUserLocal(user, args)" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="pager-bar">
                    <span class="text-muted">Page @_groupUserPage.Page of @_groupUserPage.TotalPages</span>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="GoToPreviousGroupUserPageAsync" disabled="@(_groupUserPage.Page <= 1)">Previous</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="GoToNextGroupUserPageAsync" disabled="@(_groupUserPage.Page >= _groupUserPage.TotalPages)">Next</button>
                    </div>
                </div>
            }

            <div class="mt-3 d-flex gap-2">
                <button type="button" class="btn btn-primary" @onclick="SaveGroupMembersAsync" disabled="@(!_memberAssignmentsDirty || _isSavingMembers)">
                    @(_isSavingMembers ? "Saving..." : "Save members")
                </button>
                <button type="button" class="btn btn-outline-secondary" @onclick="ResetGroupMemberEditsAsync" disabled="@(!_memberAssignmentsDirty || _isSavingMembers)">Reset members</button>
            </div>
        </section>
    }
}

@code {
    private readonly int[] _pageSizeOptions = [20, 30, 50, 100];

    [SupplyParameterFromForm(FormName = "admin-group-create")]
    private CreateGroupRequest? PostedGroupDraft { get; set; }

    private CreateGroupRequest GroupDraft => PostedGroupDraft ??= new();
    private UserContext? _currentUser;
    private GroupListQuery _groupQuery = new() { PageSize = 20, SortField = "name" };
    private PagedResult<GroupOverview> _groupPage = new(Array.Empty<GroupOverview>(), 0, 1, 20, 1);
    private GroupUserMembershipQuery _groupUserQuery = new() { PageSize = 20, SortField = "displayName" };
    private PagedResult<GroupUserAccessRow> _groupUserPage = new(Array.Empty<GroupUserAccessRow>(), 0, 1, 20, 1);
    private readonly Dictionary<Guid, bool> _pendingMemberAssignments = [];
    private Guid? _selectedGroupId;
    private string? _selectedGroupName;
    private bool _showCreateGroupForm;
    private bool _isCreating;
    private bool _isDeleting;
    private Guid? _deletingGroupId;
    private bool _isSavingMembers;
    private string? _message;
    private string? _error;

    private bool _memberAssignmentsDirty => _pendingMemberAssignments.Count > 0;
    private string SelectedGroupName => _selectedGroupName ?? "Selected group";

    protected override async Task OnInitializedAsync()
    {
        if (!await JournalApp.HasCurrentUserAsync())
        {
            Navigation.NavigateTo("/", forceLoad: false);
            return;
        }

        _currentUser = await JournalApp.GetCurrentUserAsync();
        await LoadGroupsAsync();
    }

    private Task LoadGroupsAsync()
    {
        _groupPage = JournalApp.GetGroups(_groupQuery);
        return Task.CompletedTask;
    }

    private Task LoadGroupUsersAsync()
    {
        if (!_selectedGroupId.HasValue)
        {
            _groupUserPage = new PagedResult<GroupUserAccessRow>(Array.Empty<GroupUserAccessRow>(), 0, 1, _groupUserQuery.PageSize, 1);
            return Task.CompletedTask;
        }

        _groupUserQuery.GroupId = _selectedGroupId.Value;
        _groupUserPage = JournalApp.GetGroupUsers(_groupUserQuery);
        return Task.CompletedTask;
    }

    private void ToggleCreateGroupForm()
    {
        _showCreateGroupForm = !_showCreateGroupForm;
        if (!_showCreateGroupForm)
        {
            ResetGroupForm();
        }
    }

    private async Task CreateGroupAsync()
    {
        ClearMessages();
        _isCreating = true;
        Logger.LogInformation("Admin group form submit: CreateGroup {GroupName}", GroupDraft.Name);

        try
        {
            var group = JournalApp.CreateGroup(GroupDraft);
            _message = $"Group '{group.Name}' created.";
            ResetGroupForm();
            _showCreateGroupForm = false;
            await LoadGroupsAsync();
            await SelectGroupAsync(group.GroupId, group.Name, resetMemberQuery: true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Admin group create failed");
            _error = ex.Message;
        }
        finally
        {
            _isCreating = false;
        }
    }

    private async Task DeleteGroupAsync(Guid groupId, string groupName)
    {
        if (groupId == Guid.Empty)
        {
            return;
        }

        ClearMessages();
        _isDeleting = true;
        _deletingGroupId = groupId;

        try
        {
            var deleted = JournalApp.DeleteGroup(groupId);
            _message = deleted
                ? $"Group '{groupName}' deleted."
                : $"Group '{groupName}' was already removed.";

            if (deleted && _selectedGroupId == groupId)
            {
                ClearSelectedGroup();
            }

            await LoadGroupsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Admin group delete failed for GroupId={GroupId}", groupId);
            _error = ex.Message;
        }
        finally
        {
            _isDeleting = false;
            _deletingGroupId = null;
        }
    }

    private async Task ToggleManageMembersAsync(Guid groupId, string groupName)
    {
        if (_selectedGroupId == groupId)
        {
            ClearSelectedGroup();
            return;
        }

        await SelectGroupAsync(groupId, groupName, resetMemberQuery: true);
    }

    private async Task SelectGroupAsync(Guid groupId, string groupName, bool resetMemberQuery)
    {
        _selectedGroupId = groupId;
        _selectedGroupName = groupName;
        _pendingMemberAssignments.Clear();

        if (resetMemberQuery)
        {
            _groupUserQuery = new GroupUserMembershipQuery { PageSize = _groupUserQuery.PageSize, SortField = "displayName" };
        }
        else
        {
            _groupUserQuery.Page = 1;
        }

        await LoadGroupUsersAsync();
    }

    private async Task SaveGroupMembersAsync()
    {
        if (!_selectedGroupId.HasValue)
        {
            _error = "Select a group first.";
            return;
        }

        if (!_memberAssignmentsDirty)
        {
            _message = $"No member changes to save for group '{SelectedGroupName}'.";
            _error = null;
            return;
        }

        try
        {
            _isSavingMembers = true;
            _message = null;
            _error = null;

            foreach (var (userId, shouldBeAssigned) in _pendingMemberAssignments)
            {
                var request = new AssignUserToGroupRequest { UserId = userId, GroupId = _selectedGroupId.Value };
                if (shouldBeAssigned)
                {
                    JournalApp.AssignUserToGroup(request);
                }
                else
                {
                    JournalApp.RemoveUserFromGroup(request);
                }
            }

            _pendingMemberAssignments.Clear();
            await LoadGroupsAsync();
            await LoadGroupUsersAsync();
            _message = $"Members updated for group '{SelectedGroupName}'.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Saving group members failed for GroupId={GroupId}", _selectedGroupId);
            _error = ex.Message;
        }
        finally
        {
            _isSavingMembers = false;
        }
    }

    private Task ResetGroupMemberEditsAsync()
    {
        _pendingMemberAssignments.Clear();
        return LoadGroupUsersAsync();
    }

    private void ToggleUserLocal(GroupUserAccessRow user, ChangeEventArgs args)
    {
        var isChecked = ParseCheckboxValue(args);
        if (isChecked == user.IsAssigned)
        {
            _pendingMemberAssignments.Remove(user.UserId);
            return;
        }

        _pendingMemberAssignments[user.UserId] = isChecked;
    }

    private bool IsUserAssigned(GroupUserAccessRow row)
        => _pendingMemberAssignments.TryGetValue(row.UserId, out var value) ? value : row.IsAssigned;

    private bool IsManagingGroup(Guid groupId)
        => _selectedGroupId == groupId;

    private void ClearSelectedGroup()
    {
        _selectedGroupId = null;
        _selectedGroupName = null;
        _pendingMemberAssignments.Clear();
        _groupUserPage = new PagedResult<GroupUserAccessRow>(Array.Empty<GroupUserAccessRow>(), 0, 1, _groupUserQuery.PageSize, 1);
    }

    private async Task OnSearchChanged(ChangeEventArgs args)
    {
        _groupQuery.FilterText = args.Value?.ToString() ?? string.Empty;
        _groupQuery.Page = 1;
        await LoadGroupsAsync();
    }

    private async Task OnPageSizeChanged(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var pageSize) && _pageSizeOptions.Contains(pageSize))
        {
            _groupQuery.PageSize = pageSize;
            _groupQuery.Page = 1;
            await LoadGroupsAsync();
        }
    }

    private async Task ChangeSortAsync(string field)
    {
        if (string.Equals(_groupQuery.SortField, field, StringComparison.OrdinalIgnoreCase))
        {
            _groupQuery.SortDirection = _groupQuery.SortDirection == SortDirection.Asc ? SortDirection.Desc : SortDirection.Asc;
        }
        else
        {
            _groupQuery.SortField = field;
            _groupQuery.SortDirection = SortDirection.Asc;
        }

        _groupQuery.Page = 1;
        await LoadGroupsAsync();
    }

    private async Task GoToPreviousPageAsync()
    {
        if (_groupQuery.Page > 1)
        {
            _groupQuery.Page--;
            await LoadGroupsAsync();
        }
    }

    private async Task GoToNextPageAsync()
    {
        if (_groupQuery.Page < _groupPage.TotalPages)
        {
            _groupQuery.Page++;
            await LoadGroupsAsync();
        }
    }

    private async Task OnGroupUserSearchChanged(ChangeEventArgs args)
    {
        _groupUserQuery.FilterText = args.Value?.ToString() ?? string.Empty;
        _groupUserQuery.Page = 1;
        await LoadGroupUsersAsync();
    }

    private async Task OnGroupUserAssignedFilterChanged(ChangeEventArgs args)
    {
        _groupUserQuery.Assigned = (args.Value?.ToString() ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "assigned" => true,
            "unassigned" => false,
            _ => null
        };

        _groupUserQuery.Page = 1;
        await LoadGroupUsersAsync();
    }

    private async Task OnGroupUserPageSizeChanged(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var pageSize) && _pageSizeOptions.Contains(pageSize))
        {
            _groupUserQuery.PageSize = pageSize;
            _groupUserQuery.Page = 1;
            await LoadGroupUsersAsync();
        }
    }

    private async Task ChangeGroupUserSortAsync(string field)
    {
        if (string.Equals(_groupUserQuery.SortField, field, StringComparison.OrdinalIgnoreCase))
        {
            _groupUserQuery.SortDirection = _groupUserQuery.SortDirection == SortDirection.Asc ? SortDirection.Desc : SortDirection.Asc;
        }
        else
        {
            _groupUserQuery.SortField = field;
            _groupUserQuery.SortDirection = SortDirection.Asc;
        }

        _groupUserQuery.Page = 1;
        await LoadGroupUsersAsync();
    }

    private async Task GoToPreviousGroupUserPageAsync()
    {
        if (_groupUserQuery.Page > 1)
        {
            _groupUserQuery.Page--;
            await LoadGroupUsersAsync();
        }
    }

    private async Task GoToNextGroupUserPageAsync()
    {
        if (_groupUserQuery.Page < _groupUserPage.TotalPages)
        {
            _groupUserQuery.Page++;
            await LoadGroupUsersAsync();
        }
    }

    private void ResetGroupForm()
    {
        GroupDraft.Name = string.Empty;
        GroupDraft.Description = string.Empty;
    }

    private void ClearMessages()
    {
        _message = null;
        _error = null;
    }

    private static bool ParseCheckboxValue(ChangeEventArgs args)
    {
        if (args.Value is bool boolValue)
        {
            return boolValue;
        }

        return bool.TryParse(args.Value?.ToString(), out var parsed) && parsed;
    }

    private static string SortGlyph(string field, string currentField, SortDirection currentDirection)
        => string.Equals(currentField, field, StringComparison.OrdinalIgnoreCase)
            ? currentDirection == SortDirection.Asc ? "\u2191" : "\u2193"
            : string.Empty;

    private static string FormatList(IReadOnlyList<string> values)
        => values.Count == 0 ? "-" : string.Join(", ", values);

    private static string RenderValueOrDash(string? value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value;
}
