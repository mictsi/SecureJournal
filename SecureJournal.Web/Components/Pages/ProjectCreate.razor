@page "/admin/projects/create"
@page "/admin/projects/create/{Step:int}"
@attribute [Authorize(Roles = "Administrator")]
@implements IAsyncDisposable
@inject ISecureJournalAppService JournalApp
@inject ProjectCreateWizardState WizardState
@inject NavigationManager Navigation
@inject ILogger<ProjectCreate> Logger
@inject IJSRuntime JS

<PageTitle>Create project</PageTitle>

<section class="page-head">
    <div>
        <p class="eyebrow">Administration</p>
        <h2>Create project</h2>
        <p>Step @CurrentStep of 3: @StepTitle</p>
    </div>
</section>

<section class="panel-card project-create-progress">
    <div class="project-create-progress-labels">
        <span>Progress</span>
        <span>@ProgressPercent%</span>
    </div>
    <div class="progress" role="progressbar" aria-label="Create project wizard progress" aria-valuenow="@ProgressPercent" aria-valuemin="0" aria-valuemax="100">
        <div class="progress-bar" style="width:@($"{ProgressPercent}%")"></div>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger" role="alert">@_error</div>
}

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert alert-success" role="alert">@_message</div>
}

@if (_currentUser is null)
{
    <p>Loading current user...</p>
}
else if (_currentUser.Role != AppRole.Administrator)
{
    <div class="alert alert-warning" role="alert">
        Administrator access is required. Current user: <strong>@_currentUser.DisplayName</strong> (@_currentUser.Role).
    </div>
}
else if (CurrentStep == 1)
{
    <section class="panel-card project-create-card">
        <div class="panel-card-header">
            <h3>Step 1: Project Information</h3>
        </div>

        <EditForm Model="WizardState.ProjectDraft" OnValidSubmit="GoToStepTwoAsync" FormName="admin-project-create-step-1">
            <AntiforgeryToken />
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="project-metadata-grid">
                <div class="project-metadata-main">
                    <label class="form-label" for="projectName">Name</label>
                    <InputText id="projectName" class="form-control" maxlength="100" @bind-Value="WizardState.ProjectDraft.Name" />
                </div>

                <div class="project-metadata-main">
                    <label class="form-label" for="projectDescription">Description</label>
                    <div class="journal-editor-shell">
                        <InputTextArea id="projectDescription"
                                       class="form-control journal-rich-editor-source"
                                       rows="8"
                                       maxlength="500"
                                       @bind-Value="WizardState.ProjectDraft.Description" />
                        <p class="journal-editor-hint">Use the built-in editor toolbar for project context, lists, and links.</p>
                    </div>
                    <small class="text-muted">Project code is generated automatically (for example PRJ0001).</small>
                </div>

                <div>
                    <label class="form-label" for="projectOwner">Project Owner</label>
                    <InputText id="projectOwner" class="form-control" maxlength="100" @bind-Value="WizardState.ProjectDraft.ProjectOwner" />
                </div>
                <div>
                    <label class="form-label" for="projectDepartment">Department</label>
                    <InputText id="projectDepartment" class="form-control" maxlength="100" @bind-Value="WizardState.ProjectDraft.Department" />
                </div>
                <div>
                    <label class="form-label" for="projectEmail">Project owner email</label>
                    <InputText id="projectEmail" class="form-control" maxlength="254" @bind-Value="WizardState.ProjectDraft.ProjectEmail" />
                </div>
                <div>
                    <label class="form-label" for="projectPhone">Project owner phone</label>
                    <InputText id="projectPhone" class="form-control" maxlength="32" @bind-Value="WizardState.ProjectDraft.ProjectPhone" />
                </div>
            </div>

            <div class="mt-4 d-flex justify-content-between">
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelWizard">Cancel</button>
                <button type="submit" class="btn btn-primary">Next</button>
            </div>
        </EditForm>
    </section>
}
else if (CurrentStep == 2)
{
    <section class="panel-card project-create-card">
        <div class="panel-card-header">
            <h3>Step 2: Group Permissions</h3>
        </div>

        <p class="project-create-step-copy">Choose existing groups or create new groups to assign to this project.</p>

        <div class="project-create-mode-toggle">
            <div class="form-check">
                <input class="form-check-input" id="useExistingGroups" type="radio" name="groupMode" checked="@WizardState.UseExistingGroups" @onchange="() => SetGroupMode(true)" />
                <label class="form-check-label" for="useExistingGroups">Choose Existing Groups</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" id="createNewGroups" type="radio" name="groupMode" checked="@(!WizardState.UseExistingGroups)" @onchange="() => SetGroupMode(false)" />
                <label class="form-check-label" for="createNewGroups">Create New Group</label>
            </div>
        </div>

        @if (WizardState.UseExistingGroups)
        {
            @if (_existingGroups.Count == 0)
            {
                <p class="mb-0">No groups exist yet. Switch to "Create New Group" to continue.</p>
            }
            else
            {
                <div class="border rounded p-3 project-create-selection-panel">
                    @foreach (var group in _existingGroups)
                    {
                        <label class="form-check mb-2">
                            <input class="form-check-input"
                                   type="checkbox"
                                   checked="@WizardState.SelectedExistingGroupIds.Contains(group.GroupId)"
                                   @onchange="args => ToggleExistingGroup(group.GroupId, args)" />
                            <span class="form-check-label">@group.Name <span class="text-muted">(@RenderValueOrDash(group.Description))</span></span>
                        </label>
                    }
                </div>
            }
        }
        else
        {
            <div class="border rounded p-3 mb-3 project-create-selection-panel">
                <div class="mb-2">
                    <label class="form-label" for="newGroupName">Group Name</label>
                    <input id="newGroupName" class="form-control" maxlength="100" @bind="_newGroupDraft.Name" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="newGroupDescription">Group Description</label>
                    <div class="journal-editor-shell">
                        <textarea id="newGroupDescription"
                                  class="form-control journal-rich-editor-source"
                                  rows="6"
                                  maxlength="500"
                                  @bind="_newGroupDraft.Description"></textarea>
                        <p class="journal-editor-hint">Use rich text if you want to describe group responsibilities or access scope.</p>
                    </div>
                </div>
                <button type="button" class="btn btn-outline-secondary" @onclick="AddNewGroupAsync">Add New Group</button>
            </div>

            @if (WizardState.NewGroups.Count == 0)
            {
                <p class="mb-0">Add at least one group to continue.</p>
            }
            else
            {
                <ul class="list-group project-create-list">
                    @foreach (var group in WizardState.NewGroups)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@group.Name</strong>
                                <div class="text-muted">@RenderValueOrDash(group.Description)</div>
                            </div>
                            <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => RemoveNewGroup(group.DraftId)">Remove</button>
                        </li>
                    }
                </ul>
            }
        }

        <div class="mt-4 d-flex justify-content-between">
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelWizard">Cancel</button>
                <button type="button" class="btn btn-outline-secondary" @onclick="GoToStepOne">Back</button>
            </div>
            @if (WizardState.UseExistingGroups)
            {
                <button type="button" class="btn btn-primary" @onclick="CreateProjectAsync" disabled="@_isSubmitting">Create Project</button>
            }
            else
            {
                <button type="button" class="btn btn-primary" @onclick="GoToStepThree">Next</button>
            }
        </div>
    </section>
}
else
{
    <section class="panel-card project-create-card">
        <div class="panel-card-header">
            <h3>Step 3: Add Group Members</h3>
        </div>

        @if (_users.Count == 0)
        {
            <p class="mb-0">No users are available to assign as group members.</p>
        }
        else
        {
            @foreach (var group in WizardState.NewGroups)
            {
                <div class="border rounded p-3 mb-3 project-create-member-card">
                    <h4 class="h6 mb-2">@group.Name</h4>
                    <p class="text-muted mb-2">@RenderValueOrDash(group.Description)</p>
                    <div class="row row-cols-1 row-cols-md-2 g-2">
                        @foreach (var user in _users)
                        {
                            <div class="col">
                                <label class="form-check">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           checked="@group.MemberUserIds.Contains(user.UserId)"
                                           @onchange="args => ToggleGroupMember(group, user.UserId, args)" />
                                    <span class="form-check-label">@user.DisplayName (@user.Username)</span>
                                </label>
                            </div>
                        }
                    </div>
                </div>
            }
        }

        <div class="mt-4 d-flex justify-content-between">
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelWizard">Cancel</button>
                <button type="button" class="btn btn-outline-secondary" @onclick="GoToStepTwo">Back</button>
            </div>
            <button type="button" class="btn btn-primary" @onclick="CreateProjectAsync" disabled="@_isSubmitting">Create Project</button>
        </div>
    </section>
}

@code {
    [Parameter] public int? Step { get; set; }

    private const int MinStep = 1;
    private const int MaxStep = 3;
    private const string WizardBaseRoute = "/admin/projects/create";
    private const string StepOneRoute = WizardBaseRoute;
    private const string StepTwoRoute = $"{WizardBaseRoute}/2";
    private const string StepThreeRoute = $"{WizardBaseRoute}/3";
    private const string StartPageRoute = "/projects";

    private UserContext? _currentUser;
    private string? _message;
    private string? _error;
    private bool _isSubmitting;
    private CreateGroupRequest _newGroupDraft = new();
    private List<GroupOverview> _existingGroups = [];
    private List<UserOverview> _users = [];
    private readonly string[] _editorIds = ["projectDescription", "newGroupDescription"];

    private int CurrentStep { get; set; } = MinStep;

    private string StepTitle => CurrentStep switch
    {
        1 => "Project Information",
        2 => "Group Permissions",
        _ => "Add Group Members"
    };

    private int ProgressPercent => CurrentStep switch
    {
        1 => 33,
        2 => 67,
        _ => 100
    };

    protected override async Task OnInitializedAsync()
    {
        if (!await JournalApp.HasCurrentUserAsync())
        {
            Navigation.NavigateTo("/", forceLoad: false);
            return;
        }

        _currentUser = await JournalApp.GetCurrentUserAsync();
        _existingGroups = JournalApp.GetGroups().OrderBy(g => g.Name, StringComparer.OrdinalIgnoreCase).ToList();
        _users = JournalApp.GetUsers().OrderBy(u => u.Username, StringComparer.OrdinalIgnoreCase).ToList();
    }

    protected override void OnParametersSet()
    {
        if (Step is null)
        {
            WizardState.Reset();
        }

        CurrentStep = Step.GetValueOrDefault(1);
        if (CurrentStep < MinStep || CurrentStep > MaxStep)
        {
            CurrentStep = MinStep;
            Navigation.NavigateTo(StepOneRoute, forceLoad: false);
            return;
        }

        if (CurrentStep >= 2 && string.IsNullOrWhiteSpace(WizardState.ProjectDraft.Name))
        {
            Navigation.NavigateTo(StepOneRoute, forceLoad: false);
            return;
        }

        if (CurrentStep == 3 && (WizardState.UseExistingGroups || WizardState.NewGroups.Count == 0))
        {
            Navigation.NavigateTo(StepTwoRoute, forceLoad: false);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var editors = new List<object>();

        if (CurrentStep == 1)
        {
            editors.Add(new
            {
                id = "projectDescription",
                value = WizardState.ProjectDraft.Description ?? string.Empty,
                minHeight = 220
            });
        }
        else if (CurrentStep == 2 && !WizardState.UseExistingGroups)
        {
            editors.Add(new
            {
                id = "newGroupDescription",
                value = _newGroupDraft.Description ?? string.Empty,
                minHeight = 180
            });
        }

        await JS.InvokeVoidAsync("secureJournalEditors.syncTinyMce", editors, _editorIds);
    }

    private Task GoToStepTwoAsync()
    {
        ClearMessages();
        Navigation.NavigateTo(StepTwoRoute, forceLoad: false);
        return Task.CompletedTask;
    }

    private void GoToStepOne()
    {
        ClearMessages();
        Navigation.NavigateTo(StepOneRoute, forceLoad: false);
    }

    private void GoToStepTwo()
    {
        ClearMessages();
        Navigation.NavigateTo(StepTwoRoute, forceLoad: false);
    }

    private void GoToStepThree()
    {
        ClearMessages();
        if (WizardState.NewGroups.Count == 0)
        {
            _error = "Add at least one new group before continuing.";
            return;
        }

        Navigation.NavigateTo(StepThreeRoute, forceLoad: false);
    }

    private void CancelWizard()
    {
        WizardState.Reset();
        Navigation.NavigateTo(StartPageRoute, forceLoad: false);
    }

    private void SetGroupMode(bool useExistingGroups)
    {
        ClearMessages();
        WizardState.UseExistingGroups = useExistingGroups;
        if (useExistingGroups)
        {
            WizardState.NewGroups.Clear();
            _newGroupDraft = new();
        }
        else
        {
            WizardState.SelectedExistingGroupIds.Clear();
        }
    }

    private void ToggleExistingGroup(Guid groupId, ChangeEventArgs args)
    {
        if (ParseCheckboxValue(args))
        {
            WizardState.SelectedExistingGroupIds.Add(groupId);
            return;
        }

        WizardState.SelectedExistingGroupIds.Remove(groupId);
    }

    private async Task AddNewGroupAsync()
    {
        ClearMessages();
        await SyncEditorValuesAsync();
        var name = (_newGroupDraft.Name ?? string.Empty).Trim();
        var description = (_newGroupDraft.Description ?? string.Empty).Trim();

        if (string.IsNullOrWhiteSpace(name))
        {
            _error = "Group name is required.";
            return;
        }

        if (_existingGroups.Any(group => string.Equals(group.Name, name, StringComparison.OrdinalIgnoreCase))
            || WizardState.NewGroups.Any(group => string.Equals(group.Name, name, StringComparison.OrdinalIgnoreCase)))
        {
            _error = $"Group '{name}' already exists.";
            return;
        }

        WizardState.NewGroups.Add(new WizardGroupDraft
        {
            Name = name,
            Description = description
        });

        _newGroupDraft = new();
    }

    private void RemoveNewGroup(Guid draftId)
    {
        ClearMessages();
        WizardState.NewGroups.RemoveAll(group => group.DraftId == draftId);
    }

    private void ToggleGroupMember(WizardGroupDraft group, Guid userId, ChangeEventArgs args)
    {
        if (ParseCheckboxValue(args))
        {
            group.MemberUserIds.Add(userId);
            return;
        }

        group.MemberUserIds.Remove(userId);
    }

    private Task CreateProjectAsync()
    {
        if (_isSubmitting)
        {
            return Task.CompletedTask;
        }

        ClearMessages();
        _isSubmitting = true;
        Logger.LogInformation("Admin project wizard submit: CreateProject");

        try
        {
            var project = JournalApp.CreateProject(new CreateProjectRequest
            {
                Code = WizardState.ProjectDraft.Code,
                Name = WizardState.ProjectDraft.Name,
                Description = WizardState.ProjectDraft.Description,
                ProjectEmail = WizardState.ProjectDraft.ProjectEmail,
                ProjectPhone = WizardState.ProjectDraft.ProjectPhone,
                ProjectOwner = WizardState.ProjectDraft.ProjectOwner,
                Department = WizardState.ProjectDraft.Department
            });

            if (WizardState.UseExistingGroups)
            {
                foreach (var groupId in WizardState.SelectedExistingGroupIds)
                {
                    JournalApp.AssignGroupToProject(new AssignGroupToProjectRequest
                    {
                        ProjectId = project.ProjectId,
                        GroupId = groupId
                    });
                }
            }
            else
            {
                foreach (var draft in WizardState.NewGroups)
                {
                    var group = JournalApp.CreateGroup(new CreateGroupRequest
                    {
                        Name = draft.Name,
                        Description = draft.Description
                    });

                    JournalApp.AssignGroupToProject(new AssignGroupToProjectRequest
                    {
                        ProjectId = project.ProjectId,
                        GroupId = group.GroupId
                    });

                    foreach (var userId in draft.MemberUserIds)
                    {
                        JournalApp.AssignUserToGroup(new AssignUserToGroupRequest
                        {
                            UserId = userId,
                            GroupId = group.GroupId
                        });
                    }
                }
            }

            WizardState.Reset();
            Navigation.NavigateTo(StartPageRoute, forceLoad: false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Admin project wizard create failed");
            _error = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }

        return Task.CompletedTask;
    }

    private void ClearMessages()
    {
        _message = null;
        _error = null;
    }

    private static bool ParseCheckboxValue(ChangeEventArgs args)
    {
        return args.Value switch
        {
            bool boolValue => boolValue,
            string text when bool.TryParse(text, out var parsed) => parsed,
            _ => false
        };
    }

    private static string RenderValueOrDash(string? value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private async Task SyncEditorValuesAsync()
        => await JS.InvokeVoidAsync("secureJournalEditors.flush", _editorIds);

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("secureJournalEditors.dispose", _editorIds);
        }
        catch (JSDisconnectedException)
        {
            // The page is already tearing down.
        }
    }
}
