@inherits LayoutComponentBase
@inject ISecureJournalAppService JournalApp
@inject NavigationManager Navigation

@if (!_authChecked)
{
    <div class="p-4">Loading...</div>
}
else if (!_isAuthenticated)
{
    <div class="p-4">Redirecting to login...</div>
}
else
{
    <div class="page-shell">
        <aside class="sidebar-panel">
            <NavMenu />
        </aside>

        <main class="main-panel">
            <header class="app-header">
                <div>
                    <p class="app-header-label">Workspace</p>
                    <h1 class="app-header-title">Secure Journal</h1>
                </div>
            </header>

            <article class="content-panel">
                @Body
            </article>
        </main>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    private bool _authChecked;
    private bool _isAuthenticated;

    protected override async Task OnParametersSetAsync()
    {
        _isAuthenticated = await JournalApp.HasCurrentUserAsync();
        _authChecked = true;

        if (!_isAuthenticated)
        {
            Navigation.NavigateTo("/", forceLoad: false);
        }
    }
}
