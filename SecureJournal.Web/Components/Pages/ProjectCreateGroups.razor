@page "/admin/projects/create/groups"
@attribute [Authorize(Roles = "Administrator")]
@inject ISecureJournalAppService JournalApp
@inject NavigationManager Navigation
@inject ILogger<ProjectCreateGroups> Logger
@inject ProjectCreationWizardState WizardState

<PageTitle>Create project - Step 2</PageTitle>

<section class="page-head">
    <div>
        <p class="eyebrow">Administration</p>
        <h2>Create project (Step 2 of 3)</h2>
        <p>Create a new group or choose one or more existing groups for this project.</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger" role="alert">@_error</div>
}

@if (_currentUser is null)
{
    <p>Loading current user...</p>
}
else if (_currentUser.Role != AppRole.Administrator)
{
    <div class="alert alert-warning" role="alert">
        Administrator access is required. Current user: <strong>@_currentUser.DisplayName</strong> (@_currentUser.Role).
    </div>
}
else
{
    <section class="panel-card project-create-card">
        <div class="panel-card-header">
            <h3>Step 2: Group access</h3>
        </div>

        <div class="mb-3 form-check">
            <input id="createNewGroup"
                   class="form-check-input"
                   type="checkbox"
                   checked="@WizardState.CreateNewGroup"
                   @onchange="OnCreateNewGroupChanged" />
            <label class="form-check-label" for="createNewGroup">Create a new group for this project</label>
        </div>

        @if (WizardState.CreateNewGroup)
        {
            <div class="row g-2 mb-3">
                <div class="col-md-6">
                    <label class="form-label" for="groupName">New group name</label>
                    <InputText id="groupName" class="form-control" maxlength="100" @bind-Value="WizardState.NewGroupDraft.Name" />
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="groupDescription">New group description</label>
                    <InputText id="groupDescription" class="form-control" maxlength="500" @bind-Value="WizardState.NewGroupDraft.Description" />
                </div>
            </div>
        }

        <div class="mb-2">
            <h4 class="h6">Existing groups</h4>
            <p class="text-muted mb-2">Select existing groups to grant access to the new project.</p>
        </div>

        @if (_groups.Count == 0)
        {
            <p class="mb-3">No existing groups found.</p>
        }
        else
        {
            <div class="table-responsive mb-3">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Group</th>
                            <th>Description</th>
                            <th class="text-end">Assign</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var group in _groups)
                        {
                            <tr>
                                <td>@group.Name</td>
                                <td>@RenderValueOrDash(group.Description)</td>
                                <td class="text-end">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           checked="@WizardState.SelectedExistingGroupIds.Contains(group.GroupId)"
                                           @onchange="args => ToggleExistingGroup(group.GroupId, args)" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="mt-3 d-flex gap-2">
            <button type="button" class="btn btn-outline-secondary" @onclick="GoBack">Back</button>
            @if (WizardState.CreateNewGroup)
            {
                <button type="button" class="btn btn-primary" @onclick="GoToMembersStepAsync">Next</button>
            }
            else
            {
                <button type="button" class="btn btn-primary" @onclick="CreateProjectAsync">Create Project</button>
            }
            <button type="button" class="btn btn-outline-secondary" @onclick="CancelWizard">Cancel</button>
        </div>
    </section>
}

@code {
    private UserContext? _currentUser;
    private List<GroupOverview> _groups = [];
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (!await JournalApp.HasCurrentUserAsync())
        {
            Navigation.NavigateTo("/", forceLoad: false);
            return;
        }

        _currentUser = await JournalApp.GetCurrentUserAsync();
        if (!WizardState.HasProjectDetails())
        {
            Navigation.NavigateTo("/admin/projects/create", forceLoad: false);
            return;
        }

        _groups = JournalApp.GetGroups()
            .OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private Task GoToMembersStepAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(WizardState.NewGroupDraft.Name))
        {
            _error = "New group name is required.";
            return Task.CompletedTask;
        }

        Navigation.NavigateTo("/admin/projects/create/members", forceLoad: false);
        return Task.CompletedTask;
    }

    private Task CreateProjectAsync()
    {
        _error = null;
        if (WizardState.SelectedExistingGroupIds.Count == 0)
        {
            _error = "Select at least one existing group or create a new group.";
            return Task.CompletedTask;
        }

        try
        {
            WizardState.Complete(JournalApp);
            WizardState.Reset();
            Navigation.NavigateTo("/admin/projects", forceLoad: false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Admin project wizard completion failed at group step");
            _error = ex.Message;
        }

        return Task.CompletedTask;
    }

    private void ToggleExistingGroup(Guid groupId, ChangeEventArgs args)
    {
        if (args.Value is bool isAssigned)
        {
            if (isAssigned)
            {
                WizardState.SelectedExistingGroupIds.Add(groupId);
            }
            else
            {
                WizardState.SelectedExistingGroupIds.Remove(groupId);
            }
        }
    }

    private void OnCreateNewGroupChanged(ChangeEventArgs args)
    {
        if (args.Value is bool createNewGroup)
        {
            WizardState.CreateNewGroup = createNewGroup;
            if (!createNewGroup)
            {
                WizardState.NewGroupDraft.Name = string.Empty;
                WizardState.NewGroupDraft.Description = string.Empty;
                WizardState.SelectedNewGroupMemberIds.Clear();
            }
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/admin/projects/create", forceLoad: false);
    }

    private void CancelWizard()
    {
        WizardState.Reset();
        Navigation.NavigateTo("/admin/projects", forceLoad: false);
    }

    private static string RenderValueOrDash(string? value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value;
}
